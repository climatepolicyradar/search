remote-visit:
    #!/usr/bin/env bash
    set -e
    vespa_read_token=$(aws ssm get-parameter --name "/search/vespa/read_token" --query "Parameter.Value" --output text --with-decryption)
    vespa_endpoint=$(aws ssm get-parameter --name "/search/vespa/endpoint" --query "Parameter.Value" --output text --with-decryption)
    mkdir -p ../.data_cache/vespa
    uv run vespa visit --target $vespa_endpoint --header "Authorization: Bearer $vespa_read_token" > "../.data_cache/vespa/documents-cloud.jsonl"
    echo "Exported to ../.data_cache/vespa/documents-cloud.jsonl"

remote-get-document id="CCLW.collection.1755.0":
    #!/usr/bin/env bash
    set -e
    vespa_read_token=$(aws ssm get-parameter --name "/search/vespa/read_token" --query "Parameter.Value" --output text --with-decryption)
    vespa_endpoint=$(aws ssm get-parameter --name "/search/vespa/endpoint" --query "Parameter.Value" --output text --with-decryption)
    uv run vespa document get "id:documents:documents::{{ id }}" --target $vespa_endpoint --header "Authorization: Bearer $vespa_read_token"

remote-delete-document id:
    #!/usr/bin/env bash
    set -e
    vespa_write_token=$(aws ssm get-parameter --name "/search/vespa/write_token" --query "Parameter.Value" --output text --with-decryption)
    vespa_endpoint=$(aws ssm get-parameter --name "/search/vespa/endpoint" --query "Parameter.Value" --output text --with-decryption)
    uv run vespa document remove "id:documents:documents::{{ id }}" --target $vespa_endpoint --header "Authorization: Bearer $vespa_write_token"

remote-get-labels hits="10":
    #!/usr/bin/env bash
    set -e
    vespa_read_token=$(aws ssm get-parameter --name "/search/vespa/read_token" --query "Parameter.Value" --output text --with-decryption)
    vespa_endpoint=$(aws ssm get-parameter --name "/search/vespa/endpoint" --query "Parameter.Value" --output text --with-decryption)
    curl -G "$vespa_endpoint/search/" \
     --header "Authorization: Bearer $vespa_read_token" \
     --data-urlencode 'yql=select * from labels where true' \
     --data-urlencode 'hits={{ hits }}'

