schema labels {
    document labels {
        field id type string {
            indexing: attribute | summary
        }
        field type type string {
            indexing: attribute | summary
        }
        field value type string {
            indexing: index | attribute | summary
            stemming: multiple
            linguistics {
                profile {
                    index: label_analysis
                }
            }
        }
        field alternative_labels type array<string> {
            indexing: index | attribute | summary
            stemming: multiple
            linguistics {
                profile {
                    index: label_analysis
                }
            }
        }
        field subconcept_labels type array<string> {
            indexing: index | attribute | summary
            stemming: multiple
            linguistics {
                profile {
                    index: label_analysis
                }
            }
        }
        field description type string {
            indexing: index | attribute | summary
        }
        field negative_labels type array<string> {
            indexing: attribute | summary
        }
        field label_source type string {
            indexing: summary
        }

        struct label {
            field id type string {}
            field type type string {}
            field value type string {}
            field timestamp type long {}
            field relationship type string {}
        }
        field labels type array<label> {
            struct-field id {
                indexing: summary | attribute
                attribute: fast-search
            }
            struct-field type {
                indexing: summary | attribute
                attribute: fast-search
            }
            struct-field value {
                indexing: summary | attribute
                attribute: fast-search
            }
            struct-field timestamp {
                indexing: summary | attribute
                attribute: fast-search
            }
            struct-field relationship {
                indexing: summary | attribute
                attribute: fast-search
            }
        }
    }

    field value_attribute type string {
        indexing: input value | attribute
    }
    field alternative_labels_attribute type array<string> {
        indexing: input alternative_labels | attribute
    }
    field subconcept_labels_attribute type array<string> {
        indexing: input subconcept_labels | attribute
    }

    fieldset default {
        fields: value, alternative_labels, subconcept_labels
    }

    rank-profile default {
        inputs {
            query(value_weight) double: 3.0
            query(alternative_labels_weight) double: 1.5
            query(subconcept_labels_weight) double: 1.0
            query(description_weight) double: 0.0
        }
    }

    rank-profile nativerank inherits default {
        function value_score() {
            expression: query(value_weight) * (nativeRank(value) + nativeProximity(value) / 3 + fieldMatch(value).fieldCompleteness / 3)
        }
        function alternative_labels_score() {
            # nativeRank * sqrt(queryCompleteness) penalises labels which match a lower number  of terms in the query.
            # Without the sqrt, the multiplier is too aggressive.
            expression: query(alternative_labels_weight) * nativeRank(alternative_labels) * pow(elementCompleteness(alternative_labels).queryCompleteness, 0.5)
        }
        function subconcept_labels_score() {
            expression: query(subconcept_labels_weight) * nativeRank(subconcept_labels) * pow(elementCompleteness(subconcept_labels).queryCompleteness, 0.5)
        }
        function description_score() {
            expression: query(description_weight) * nativeRank(description)
        }

        first-phase {
            expression: value_score() + alternative_labels_score() + subconcept_labels_score() + description_score()
        }
        summary-features: value_score() alternative_labels_score() subconcept_labels_score() description_score() nativeRank(value) nativeRank(alternative_labels) nativeRank(subconcept_labels) nativeRank(description) nativeProximity(value) elementCompleteness(alternative_labels).queryCompleteness elementCompleteness(subconcept_labels).queryCompleteness fieldMatch(value).fieldCompleteness fieldMatch(value).queryCompleteness
    }
}
