schema passages {
    document passages {
        field id type string {
            indexing: attribute | summary
        }
        field idx type int {
            indexing: attribute | summary
        }
        field language type string {
            indexing: attribute | summary
        }
        field text type string {
            indexing: index | summary
        }
        field document_id type string {
            indexing: attribute | summary
        }
        field document_ref type reference<documents> {
            indexing: attribute
        }
        field principal_document_ref type reference<documents> {
            indexing: attribute
        }
        field type type string {
            indexing: attribute | summary
        }
        field type_confidence type double {
            indexing: attribute | summary
        }
        field page_number type int {
            indexing: attribute | summary
        }
        field pages type array<int> {
            indexing: attribute | summary
            attribute: fast-search
            rank: filter
        }
        field heading_id type string {
            indexing: attribute | summary
        }
        struct concept {
            field id type string {}
            field type type string {}
            field value type string {}
            field count type int {}
        }
        field concepts type array<concept> {
            struct-field id {
                indexing: summary | attribute
                attribute: fast-search
            }
            struct-field type {
                indexing: summary | attribute
                attribute: fast-search
            }
            struct-field value {
                indexing: summary | attribute
                attribute: fast-search
            }
            struct-field count {
                indexing: summary | attribute
                attribute: fast-search
            }
        }
        field heading_text type string {
            indexing: index | summary
        }
    }

    # Fields imported from the parent document via document_ref. These let us
    # filter and group passages on document-level metadata without denormalising it
    # onto each passage.
    import field document_ref.principal_id as principal_id {}
    import field document_ref.geographies_attribute as geographies {}
    import field document_ref.labels_type_id_value_attribute as labels_type_id_value_attribute {}
    import field document_ref.concepts_type_id_value_attribute as concepts_type_id_value_attribute {}
    import field document_ref.attributes_published_date as attributes_published_date {}

    # Fields imported from the Principal document via principal_document_ref.
    # Lets passages filter / group / return Principal-scoped metadata in one
    # hop without denormalising per-passage.
    import field principal_document_ref.title_attribute as principal_title {}

    field concepts_value type array<string> {
        indexing: input concepts | for_each { get_field value } | index | summary
        stemming: none
        linguistics {
            profile: document_label_analysis
        }
    }

    fieldset default {
        fields: text
    }

    rank-profile nativerank {
        function text_score() {
            expression: nativeRank(text) + nativeProximity(text)
        }

        first-phase {
            expression: text_score()
        }
        summary-features: text_score() nativeRank(text) nativeProximity(text)
    }

    document-summary debug-summary {
        summary id {}
        summary idx {}
        summary language {}
        summary text {}
        summary document_id {}
        summary principal_id {}
        summary type {}
        summary type_confidence {}
        summary page_number {}
        summary pages {}
        summary heading_id {}
        summary concepts {}
        summary concepts_value {}
        summary heading_text {}
        summary text_tokens {
            source: text
            tokens
        }
        from-disk
    }
}
