schema passages {
    document passages {
        field id type string {
            indexing: attribute | summary
        }
        field idx type int {
            indexing: attribute | summary
        }
        field language type string {
            indexing: attribute | summary
        }
        field text type string {
            indexing: index | attribute | summary
            stemming: multiple
            linguistics {
                profile: passage_analysis
            }
        }
        field document_id type string {
            indexing: attribute | summary
        }
        field type type string {
            indexing: attribute | summary
        }
        field type_confidence type double {
            indexing: attribute | summary
        }
        field page_number type int {
            indexing: attribute | summary
        }
        field heading_id type string {
            indexing: attribute | summary
        }
    }

    # Uses title_analysis (no stop words) rather than passage_analysis because
    # some synonyms contain stop words (e.g. "global goal on adaptation").
    # Both index and search profiles must be consistent — no stop words on either side.
    field text_synonyms type string {
        indexing: input text | index
        stemming: multiple
        linguistics {
            profile {
                index: title_analysis
                search: passage_synonym_analysis_search
            }
        }
    }

    fieldset default {
        fields: text
    }

    fieldset text_synonyms_fieldset {
        fields: text_synonyms
    }

    rank-profile nativerank {
        function text_score() {
            expression: nativeRank(text) + nativeProximity(text)
        }
        function text_synonyms_score() {
            expression: nativeRank(text_synonyms)
        }

        first-phase {
            expression: text_score() + text_synonyms_score()
        }
        summary-features: text_score() text_synonyms_score() nativeRank(text) nativeProximity(text) nativeRank(text_synonyms)
    }

    document-summary debug-summary {
        summary id {}
        summary idx {}
        summary language {}
        summary text {}
        summary document_id {}
        summary type {}
        summary type_confidence {}
        summary page_number {}
        summary heading_id {}
        summary text_tokens {
            source: text
            tokens
        }
        summary text_synonyms_tokens {
            source: text_synonyms
            tokens
        }
        from-disk
    }
}
