# Copy to .env and fill in values
# ----------------------------------------
# S3 source
VESPA_FEEDER_S3_BUCKET=cpr-cache
VESPA_FEEDER_S3_KEY=search/vespa/documents_feed_materializer.jsonl.gz

# Vespa target
# Local:
VESPA_FEEDER_VESPA_URL=http://localhost:8080
# Vespa Cloud (comment out local line above and uncomment these):
# VESPA_FEEDER_VESPA_URL=https://my-app.vespa-cloud.com
# VESPA_FEEDER_VESPA_WRITE_TOKEN=vespa-write-token-here

# Human label for logs
VESPA_FEEDER_INDEX_NAME=documents

# AWS
AWS_PROFILE=labs
AWS_REGION=eu-west-1
