          },
          {
            "matcher": { "id": "byName", "options": "OK" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Feeder Errors" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "custom.width", "value": 120 }
