    {
      "datasource": {
        "type": "loki",
        "uid": "grafanacloud-climatepolicyradar-logs"
      },
      "description": "One row per run that reached the Vespa feed step, parsed from 'vespa feed stats' log lines. Status is derived from total errors (feeder + HTTP). Runs that fail before feeding (e.g. S3 download error) do not appear here.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": false,
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": { "color": "green", "index": 0, "text": "OK" }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "from": 1,
                      "result": { "color": "red", "index": 1, "text": "FAIL" }
                    },
                    "type": "range"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background" }
              },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Deployment" },
            "properties": [{ "id": "custom.width", "value": 200 }]
          },
          {
            "matcher": { "id": "byName", "options": "Run" },
