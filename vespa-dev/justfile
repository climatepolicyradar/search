
# Vespa Cloud relevance-experiment workflow
#
# Prereqs (once per machine):
#   vespa auth login
#   vespa auth cert -a <dev_app>          # data-plane cert for the dev application
#   pip install prefect                   # or: uv add prefect / poetry add prefect
#   jq, aws CLI configured                 # used by `create`/`destroy` to store/clear the instance's endpoint in SSM
#
# Adjust tenant/dev_app/zone below to your real Vespa Cloud names.

tenant   := "climate-policy-radar"
dev_app  := tenant + ".search-dev"           # tenant.application under which personal instances live
zone     := "dev.aws-us-east-1c"
aws_region := "eu-west-1"
feed_deployment := "feed-from-production/search-vespa-dev-feed-from-production"  # see prefect_deploy.py
 
# Create the instance if it doesn't already exist yet. No-op if it's already
# there - use `just deploy` to push changes to an existing instance.
# Vespa Cloud has no separate "provision an empty instance" step: creating and
# deploying are the same API call, so this just guards `vespa deploy` behind
# an existence check via `vespa status`.
#
# Also resolves the instance's data-plane endpoint and stores it in SSM under
# /search/vespa-dev/<instance> - personal dev instances get a fresh,
# unpredictable endpoint URL on every create, so feed_from_production.py's
# feed_target task (running headless on the Prefect ECS worker, with no
# control-plane credentials) reads it from there instead of resolving it
# itself. Re-run unconditionally (even if the instance already existed) so
# this stays in sync if it's ever missing or stale.
create instance:
    #!/usr/bin/env bash
    set -euo pipefail
    app="{{dev_app}}.{{instance}}"
    # `vespa status` exits 0 even for instances that don't exist (it prints the
    # 404 to stderr but returns success), so it can't tell us whether the
    # instance is deployed
    endpoint=$(uv run vespa status endpoint -a "$app" -t cloud -z {{zone}} --format json 2>/dev/null \
        | jq -r 'select(.authMethod=="token") | .url' || true)
    if [[ -z "$endpoint" ]]; then
        echo "No endpoint for $app yet - deploying to {{zone}}"
        # Ignore a non-zero exit: --wait's post-deploy health check hits the
        # container over mTLS and fails with "tls: unknown certificate" when the
        # CLI's data-plane cert isn't trusted, even though the deploy succeeded.
        # We only need the token endpoint (feeding uses token auth, not mTLS),
        # so success is judged by whether that endpoint resolves below.
        uv run vespa deploy --wait 1800 -a "$app" -t cloud -z {{zone}} ../vespa/app || true
        endpoint=$(uv run vespa status endpoint -a "$app" -t cloud -z {{zone}} --format json 2>/dev/null \
            | jq -r 'select(.authMethod=="token") | .url' || true)
    else
        echo "Instance $app already deployed - reusing existing endpoint. Use 'just deploy {{instance}}' to push changes."
    fi
    if [[ -z "$endpoint" ]]; then
        echo "ERROR: could not resolve a token endpoint for $app - deployment may have failed" >&2
        exit 1
    fi
    aws ssm put-parameter --region {{aws_region}} \
        --name "/search/vespa-dev/{{instance}}" \
        --value "$endpoint" \
        --type SecureString \
        --overwrite >/dev/null
    echo "Stored endpoint for {{instance}} at /search/vespa-dev/{{instance}} ({{aws_region}})"
 
# Deploy your local schema/services.xml changes to an existing instance.
deploy instance:
    uv run vespa deploy -a {{dev_app}}.{{instance}} -t cloud -z {{zone}} ../vespa/app
 
# Feed the instance from a sample (or full) snapshot of prod.
feed instance sample="20":
    uv run prefect deployment run '{{feed_deployment}}' \
        -p target={{dev_app}}.{{instance}} \
        -p sample_percent={{sample}}

# Run the flow locally against your working copy
feed-local instance sample="5":
    AWS_DEFAULT_REGION={{aws_region}} uv run python feed_from_production.py \
        --target {{dev_app}}.{{instance}} \
        --sample-percent {{sample}}
 
# Tear the instance down now, rather than waiting on the 14-day auto-expiry.
destroy instance:
    uv run vespa destroy -a {{dev_app}}.{{instance}} --force
    aws ssm delete-parameter --region {{aws_region}} --name "/search/vespa-dev/{{instance}}" 2>/dev/null || true

# Snapshot production to s3://cpr-cache/search/vespa/index/ as sharded JSONL.
# Runs daily via the scheduled deployment (see prefect_deploy.py) - this is
# for triggering an ad hoc run locally.
snapshot sample="100":
    python export_production_snapshot.py --sample-percent {{sample}}

prefect_deploy:
    AWS_REGION={{aws_region}} uv run python prefect_deploy.py

# Rebuild + push the image, then re-register the deployments.
release: docker-build docker-push prefect_deploy

registry := `aws sts get-caller-identity --query Account --output text` + ".dkr.ecr." + aws_region + ".amazonaws.com"
image := registry + "/search-vespa-dev"

docker-build:
    docker build --platform=linux/amd64 -t {{ image }}:latest .

docker-push:
    aws ecr get-login-password | docker login --username AWS --password-stdin {{ registry }}
    docker push {{ image }}:latest
